# Copy to .env (the control script does this for you). docker compose reads it.

# Mapbox token so map tiles render. Get one at https://account.mapbox.com/access-tokens
DEKART_MAPBOX_TOKEN=

# Only needed for the BigQuery instance (./dekart.sh bq). Also put a
# service-account key at creds/key.json (see creds/README.txt).
GCP_PROJECT_ID=

# Set after building the patched image (custom-image/build.sh) to enable the
# "Import style" button. Leave unset to use the official image.
# DEKART_IMAGE=dekart-custom:local
