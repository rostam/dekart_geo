+function ImportStyleButton () {
+  const dispatch = useDispatch()
+  const datasets = useSelector(state => (state.keplerGl.kepler && state.keplerGl.kepler.visState) ? state.keplerGl.kepler.visState.datasets : {})
+  const inputRef = useRef(null)
+  const dataIds = Object.keys(datasets || {})
+  const onFile = (e) => {
+    const file = e.target.files && e.target.files[0]
+    e.target.value = ''
+    if (!file) return
+    const reader = new FileReader()
+    reader.onload = () => {
+      try {
+        const cfg = JSON.parse(reader.result)
+        applyStyleConfig(cfg, dataIds[0], dispatch)
+        track('ImportStyle')
+      } catch (err) {
+        window.alert('Invalid style file: ' + err.message)
+      }
+    }
+    reader.readAsText(file)
+  }
+  return (
+    <>
+      <input ref={inputRef} type='file' accept='.json,application/json' style={{ display: 'none' }} onChange={onFile} />
+      <Button
+        title={dataIds.length ? 'Import a style file (.json)' : 'Run a query first, then import a style'}
+        type='text'
+        ghost
+        icon={<BgColorsOutlined />}
+        disabled={!dataIds.length}
+        onClick={() => { if (inputRef.current) inputRef.current.click() }}
+      />
+    </>
+  )
+}
