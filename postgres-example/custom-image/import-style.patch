+
+// Apply an imported kepler style config to the current map, rebinding every
+// dataId reference to the map's current dataset so the styled layers attach.
+export function applyStyleConfig (rawConfig, dataId, dispatch) {
+  if (!dataId) {
+    window.alert('Run a query first so there is data to style.')
+    return
+  }
+  const saved = rawConfig && rawConfig.config
+    ? structuredClone(rawConfig)
+    : { version: 'v1', config: structuredClone(rawConfig) }
+  const vis = saved.config && saved.config.visState
+  if (vis) {
+    (vis.layers || []).forEach(layer => {
+      if (layer.config) layer.config.dataId = dataId
+    })
+    ;(vis.filters || []).forEach(filter => {
+      filter.dataId = Array.isArray(filter.dataId) ? filter.dataId.map(() => dataId) : dataId
+    })
+    const tooltip = vis.interactionConfig && vis.interactionConfig.tooltip
+    if (tooltip && tooltip.fieldsToShow) {
+      const fields = Object.values(tooltip.fieldsToShow)[0] || []
+      tooltip.fieldsToShow = { [dataId]: fields }
+    }
+  }
+  dispatch(receiveMapConfig(KeplerGlSchema.parseSavedConfig(saved)))
+}
