# Copy to .env and fill in your values:  cp .env.example .env

# --- Postgres (defaults are fine for local use) ---
DEKART_POSTGRES_DB=dekart
DEKART_POSTGRES_USER=dekart
DEKART_POSTGRES_PASSWORD=dekart

# --- Mapbox (required) — get a token at https://account.mapbox.com/access-tokens ---
DEKART_MAPBOX_TOKEN=

# --- BigQuery + GCS (default data source) ---
DEKART_DATASOURCE=BQ
DEKART_STORAGE=GCS
DEKART_BIGQUERY_PROJECT_ID=
DEKART_CLOUD_STORAGE_BUCKET=

# --- AWS Athena + S3 (set DEKART_DATASOURCE=ATHENA, DEKART_STORAGE=S3) ---
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# DEKART_ATHENA_CATALOG=AwsDataCatalog
# DEKART_ATHENA_S3_OUTPUT_LOCATION=s3://your-bucket/athena-results/

# --- Snowflake (set DEKART_DATASOURCE=SNOWFLAKE) ---
# DEKART_SNOWFLAKE_ACCOUNT_ID=
# DEKART_SNOWFLAKE_USER=
# DEKART_SNOWFLAKE_PASSWORD=

# Misc
DEKART_LOG_DEBUG=0
DEKART_ALLOW_FILE_UPLOAD=1
